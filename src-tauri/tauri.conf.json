{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anuj AI",
  "version": "0.1.0",
  "identifier": "com.anuj.privateai",
  "build": {
    "frontendDist": "http://localhost:8501",
    "devUrl": "http://localhost:8501",
    "beforeDevCommand": "streamlit run app.py"
  },
  "app": {
    "windows": [
      {
        "title": "Anuj AI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
